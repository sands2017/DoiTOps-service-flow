        <mxCell id="title-text" parent="1" style="text;html=1;align=center;verticalAlign=middle;resizable=0;points=[];autosize=1;" value="&lt;font color=&quot;#ffffff&quot; style=&quot;font-size:28px;&quot;&gt;&lt;b&gt;SERVICE OPERATING MODEL CANVAS&lt;/b&gt;&lt;/font&gt;&lt;br&gt;&lt;font color=&quot;#a0a0c0&quot; style=&quot;font-size:14px;&quot;&gt;DoiTOps FinOps Service | Based on &quot;The Strategy Journey&quot; by Julie Choo&lt;/font&gt;" vertex="1">
          <mxGeometry height="70" width="800" x="560" y="25" as="geometry" />
