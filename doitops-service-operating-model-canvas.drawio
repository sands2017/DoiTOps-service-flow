<mxfile host="app.diagrams.net" modified="2026-03-05T00:00:00.000Z" agent="Claude Code" version="21.0.0" type="device">
  <diagram id="service-operating-model-canvas" name="Service Operating Model Canvas">
    <mxGraphModel dx="1800" dy="1400" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="2200" pageHeight="1500" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />

        <!-- ==================== TITLE BANNER ==================== -->
        <mxCell id="title-banner" value="&lt;font color=&quot;#ffffff&quot; style=&quot;font-size:26px;&quot;&gt;&lt;b&gt;SERVICE OPERATING MODEL CANVAS&lt;/b&gt;&lt;/font&gt;&lt;br&gt;&lt;font color=&quot;#a0a0c0&quot; style=&quot;font-size:13px;&quot;&gt;DoiTOps FinOps Service | Based on &quot;The Strategy Journey&quot; by Julie Choo&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#1a1a2e;strokeColor=#16213e;arcSize=4;verticalAlign=middle;" vertex="1" parent="1">
          <mxGeometry x="40" y="20" width="2120" height="80" as="geometry" />
        </mxCell>

        <!-- ==================== ROW 1: TOP ROW (5 columns) ==================== -->

        <!-- 1. PARTNERS & SUPPLIERS -->
        <mxCell id="partners-box" value="&lt;div style=&quot;text-align:center;margin-bottom:8px;&quot;&gt;&lt;font style=&quot;font-size:14px;&quot; color=&quot;#7c4daa&quot;&gt;&lt;b&gt;PARTNERS &amp;amp; SUPPLIERS&lt;/b&gt;&lt;/font&gt;&lt;/div&gt;&lt;hr style=&quot;border:0;border-top:1px solid #c9a6e0;margin:4px 0 8px 0;&quot;&gt;&lt;div style=&quot;text-align:left;font-size:12px;line-height:1.6;&quot;&gt;&lt;b&gt;Cloud Providers&lt;/b&gt;&lt;br&gt;- Google Cloud Platform (Cloud Run)&lt;br&gt;- AWS / Azure (customer workloads)&lt;br&gt;&lt;br&gt;&lt;b&gt;Platform Partners&lt;/b&gt;&lt;br&gt;- DoiT International (DCI Platform)&lt;br&gt;- GitHub (Actions, Apps, Repos)&lt;br&gt;&lt;br&gt;&lt;b&gt;AI / Tooling&lt;/b&gt;&lt;br&gt;- Anthropic (Claude Code)&lt;br&gt;- OpenCode (plugin ecosystem)&lt;/div&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8f0ff;strokeColor=#9673a6;strokeWidth=2;arcSize=4;verticalAlign=top;spacingTop=8;spacingLeft=10;spacingRight=10;" vertex="1" parent="1">
          <mxGeometry x="40" y="120" width="400" height="320" as="geometry" />
        </mxCell>

        <!-- 2. CAPABILITIES -->
        <mxCell id="capabilities-box" value="&lt;div style=&quot;text-align:center;margin-bottom:8px;&quot;&gt;&lt;font style=&quot;font-size:14px;&quot; color=&quot;#2a6099&quot;&gt;&lt;b&gt;CAPABILITIES&lt;/b&gt;&lt;/font&gt;&lt;/div&gt;&lt;hr style=&quot;border:0;border-top:1px solid #7cb3e0;margin:4px 0 8px 0;&quot;&gt;&lt;div style=&quot;text-align:left;font-size:12px;line-height:1.6;&quot;&gt;&lt;b&gt;Upstream (Input)&lt;/b&gt;&lt;br&gt;- IaC cost evaluation (pre-commit)&lt;br&gt;- Cloud pricing API integration&lt;br&gt;- Wastage &amp;amp; anomaly detection&lt;br&gt;&lt;br&gt;&lt;b&gt;Core&lt;/b&gt;&lt;br&gt;- FinOps cost analysis &amp;amp; reporting&lt;br&gt;- Automated PR review &amp;amp; gating&lt;br&gt;- DCI dashboard orchestration&lt;br&gt;&lt;br&gt;&lt;b&gt;Downstream (Output)&lt;/b&gt;&lt;br&gt;- Cost optimisation recommendations&lt;br&gt;- Budget alerts &amp;amp; forecasting&lt;/div&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e6f2ff;strokeColor=#3a7bbf;strokeWidth=2;arcSize=4;verticalAlign=top;spacingTop=8;spacingLeft=10;spacingRight=10;" vertex="1" parent="1">
          <mxGeometry x="460" y="120" width="400" height="320" as="geometry" />
        </mxCell>

        <!-- 3. VALUE PROPOSITION (Center, gold accent) -->
        <mxCell id="value-box" value="&lt;div style=&quot;text-align:center;margin-bottom:8px;&quot;&gt;&lt;font style=&quot;font-size:14px;&quot; color=&quot;#b8860b&quot;&gt;&lt;b&gt;VALUE PROPOSITION&lt;/b&gt;&lt;/font&gt;&lt;/div&gt;&lt;hr style=&quot;border:0;border-top:2px solid #d6a800;margin:4px 0 8px 0;&quot;&gt;&lt;div style=&quot;text-align:left;font-size:12px;line-height:1.6;&quot;&gt;&lt;b&gt;Shift-Left FinOps integrated into GitOps&lt;/b&gt;&lt;br&gt;&lt;br&gt;Embed cloud cost governance directly into the developer workflow so that every commit, merge, and deployment is cost-aware.&lt;br&gt;&lt;br&gt;&lt;b&gt;Key Promises:&lt;/b&gt;&lt;br&gt;- Prevent cost surprises before they deploy&lt;br&gt;- Automate FinOps reporting in CI/CD&lt;br&gt;- Continuous post-deploy cost monitoring&lt;br&gt;- Single pane of glass via DCI dashboard&lt;br&gt;- AI-assisted cost optimisation suggestions&lt;/div&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6a800;strokeWidth=3;arcSize=4;verticalAlign=top;spacingTop=8;spacingLeft=12;spacingRight=12;" vertex="1" parent="1">
          <mxGeometry x="880" y="120" width="440" height="320" as="geometry" />
        </mxCell>

        <!-- 4. CHANNELS -->
        <mxCell id="channels-box" value="&lt;div style=&quot;text-align:center;margin-bottom:8px;&quot;&gt;&lt;font style=&quot;font-size:14px;&quot; color=&quot;#1a6b3c&quot;&gt;&lt;b&gt;CHANNELS&lt;/b&gt;&lt;/font&gt;&lt;/div&gt;&lt;hr style=&quot;border:0;border-top:1px solid #6ec08a;margin:4px 0 8px 0;&quot;&gt;&lt;div style=&quot;text-align:left;font-size:12px;line-height:1.6;&quot;&gt;&lt;b&gt;Developer Touchpoints&lt;/b&gt;&lt;br&gt;- DoiT CLI (terminal)&lt;br&gt;- Git pre-commit hooks&lt;br&gt;- GitHub PR comments &amp;amp; checks&lt;br&gt;&lt;br&gt;&lt;b&gt;AI-Assisted&lt;/b&gt;&lt;br&gt;- Claude Code plugin (/doit evaluate)&lt;br&gt;- OpenCode plugin (/dci make report)&lt;br&gt;&lt;br&gt;&lt;b&gt;Management&lt;/b&gt;&lt;br&gt;- DCI Console (web dashboard)&lt;br&gt;- Email / Slack alerts&lt;/div&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e6fff2;strokeColor=#2d8659;strokeWidth=2;arcSize=4;verticalAlign=top;spacingTop=8;spacingLeft=10;spacingRight=10;" vertex="1" parent="1">
          <mxGeometry x="1340" y="120" width="400" height="320" as="geometry" />
        </mxCell>

        <!-- 5. CUSTOMER SEGMENTS -->
        <mxCell id="customers-box" value="&lt;div style=&quot;text-align:center;margin-bottom:8px;&quot;&gt;&lt;font style=&quot;font-size:14px;&quot; color=&quot;#b32d2d&quot;&gt;&lt;b&gt;CUSTOMER SEGMENTS&lt;/b&gt;&lt;/font&gt;&lt;/div&gt;&lt;hr style=&quot;border:0;border-top:1px solid #e08a8a;margin:4px 0 8px 0;&quot;&gt;&lt;div style=&quot;text-align:left;font-size:12px;line-height:1.6;&quot;&gt;&lt;b&gt;Primary&lt;/b&gt;&lt;br&gt;- Platform / DevOps Engineers&lt;br&gt;- Cloud / Infrastructure Engineers&lt;br&gt;- SRE Teams&lt;br&gt;&lt;br&gt;&lt;b&gt;Secondary&lt;/b&gt;&lt;br&gt;- Engineering Managers&lt;br&gt;- FinOps Practitioners&lt;br&gt;- Cloud Architects&lt;br&gt;&lt;br&gt;&lt;b&gt;Executive&lt;/b&gt;&lt;br&gt;- CTOs / VPs Engineering&lt;br&gt;- Finance / Procurement&lt;/div&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffe6e6;strokeColor=#cc3333;strokeWidth=2;arcSize=4;verticalAlign=top;spacingTop=8;spacingLeft=10;spacingRight=10;" vertex="1" parent="1">
          <mxGeometry x="1760" y="120" width="400" height="320" as="geometry" />
        </mxCell>

        <!-- ==================== ROW 2: MIDDLE ROW (3 columns) ==================== -->

        <!-- 6. GOVERNANCE & CONTROLS -->
        <mxCell id="governance-box" value="&lt;div style=&quot;text-align:center;margin-bottom:8px;&quot;&gt;&lt;font style=&quot;font-size:14px;&quot; color=&quot;#6b5230&quot;&gt;&lt;b&gt;GOVERNANCE &amp;amp; CONTROLS&lt;/b&gt;&lt;/font&gt;&lt;/div&gt;&lt;hr style=&quot;border:0;border-top:1px solid #bfa67a;margin:4px 0 8px 0;&quot;&gt;&lt;div style=&quot;text-align:left;font-size:12px;line-height:1.6;&quot;&gt;&lt;b&gt;Policy &amp;amp; Standards&lt;/b&gt;&lt;br&gt;- Cost threshold policies per environment&lt;br&gt;- Tagging standards enforcement&lt;br&gt;- Budget allocation rules per team/project&lt;br&gt;- Approved resource SKU catalogues&lt;br&gt;&lt;br&gt;&lt;b&gt;Quality Gates&lt;/b&gt;&lt;br&gt;- Pre-commit: cost impact check must pass&lt;br&gt;- PR merge: FinOps report required, reviewer approval&lt;br&gt;- Post-deploy: anomaly detection within 24h SLA&lt;br&gt;&lt;br&gt;&lt;b&gt;Compliance&lt;/b&gt;&lt;br&gt;- Audit trail of all cost decisions in Git history&lt;br&gt;- Segregation of duties (commit != approve != deploy)&lt;/div&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f0eb;strokeColor=#8c6d46;strokeWidth=2;arcSize=4;verticalAlign=top;spacingTop=8;spacingLeft=10;spacingRight=10;" vertex="1" parent="1">
          <mxGeometry x="40" y="460" width="620" height="340" as="geometry" />
        </mxCell>

        <!-- 7. PROCESSES & ACTIVITIES -->
        <mxCell id="processes-box" value="&lt;div style=&quot;text-align:center;margin-bottom:8px;&quot;&gt;&lt;font style=&quot;font-size:14px;&quot; color=&quot;#2d6b2d&quot;&gt;&lt;b&gt;PROCESSES &amp;amp; ACTIVITIES&lt;/b&gt;&lt;/font&gt;&lt;/div&gt;&lt;hr style=&quot;border:0;border-top:1px solid #7abf7a;margin:4px 0 8px 0;&quot;&gt;&lt;div style=&quot;text-align:left;font-size:12px;line-height:1.5;&quot;&gt;&lt;table style=&quot;width:100%;border-collapse:collapse;font-size:12px;&quot;&gt;&lt;tr&gt;&lt;td style=&quot;padding:6px;vertical-align:top;width:33%;&quot;&gt;&lt;b&gt;Phase 1: Pre-Commit&lt;/b&gt;&lt;br&gt;1. Developer writes IaC&lt;br&gt;2. Pre-commit hook triggers&lt;br&gt;3. DoiT CLI evaluates cost&lt;br&gt;4. Wastage check runs&lt;br&gt;5. Pass/fail feedback in terminal&lt;/td&gt;&lt;td style=&quot;padding:6px;vertical-align:top;width:33%;border-left:1px solid #4a8c4a;&quot;&gt;&lt;b&gt;Phase 2: Merge &amp;amp; Approval&lt;/b&gt;&lt;br&gt;1. PR created on GitHub&lt;br&gt;2. GitHub App triggers Actions&lt;br&gt;3. FinOps report generated&lt;br&gt;4. Report posted to PR&lt;br&gt;5. Reviewer approves/rejects&lt;/td&gt;&lt;td style=&quot;padding:6px;vertical-align:top;width:33%;border-left:1px solid #4a8c4a;&quot;&gt;&lt;b&gt;Phase 3: Post-Deployment&lt;/b&gt;&lt;br&gt;1. Deployment completes&lt;br&gt;2. DCI monitors usage&lt;br&gt;3. Anomaly detection runs&lt;br&gt;4. Dashboard updates&lt;br&gt;5. Alerts if thresholds breach&lt;/td&gt;&lt;/tr&gt;&lt;/table&gt;&lt;/div&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e6f0e6;strokeColor=#4a8c4a;strokeWidth=2;arcSize=4;verticalAlign=top;spacingTop=8;spacingLeft=10;spacingRight=10;" vertex="1" parent="1">
          <mxGeometry x="680" y="460" width="860" height="340" as="geometry" />
        </mxCell>

        <!-- 8. PEOPLE & ORGANISATION -->
        <mxCell id="people-box" value="&lt;div style=&quot;text-align:center;margin-bottom:8px;&quot;&gt;&lt;font style=&quot;font-size:14px;&quot; color=&quot;#8c2d5e&quot;&gt;&lt;b&gt;PEOPLE &amp;amp; ORGANISATION&lt;/b&gt;&lt;/font&gt;&lt;/div&gt;&lt;hr style=&quot;border:0;border-top:1px solid #d98ab3;margin:4px 0 8px 0;&quot;&gt;&lt;div style=&quot;text-align:left;font-size:12px;line-height:1.6;&quot;&gt;&lt;b&gt;Roles&lt;/b&gt;&lt;br&gt;- Service Owner: FinOps Lead&lt;br&gt;- Operators: Platform Engineering Team&lt;br&gt;- Contributors: All engineers (IaC commits)&lt;br&gt;- Approvers: Tech Leads / Architects&lt;br&gt;&lt;br&gt;&lt;b&gt;Organisation Model&lt;/b&gt;&lt;br&gt;- Federated: each team owns their cost&lt;br&gt;- Central FinOps team sets policy &amp;amp; tooling&lt;br&gt;- RACI: Dev (R), FinOps (A), Architect (C), Finance (I)&lt;br&gt;&lt;br&gt;&lt;b&gt;Skills &amp;amp; Training&lt;/b&gt;&lt;br&gt;- FinOps Foundation certification&lt;br&gt;- DoiT CLI / DCI platform onboarding&lt;/div&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff0f5;strokeColor=#b34d80;strokeWidth=2;arcSize=4;verticalAlign=top;spacingTop=8;spacingLeft=10;spacingRight=10;" vertex="1" parent="1">
          <mxGeometry x="1560" y="460" width="600" height="340" as="geometry" />
        </mxCell>

        <!-- ==================== ROW 3: TECHNOLOGY & TOOLS (full width) ==================== -->

        <mxCell id="tech-box" value="&lt;div style=&quot;text-align:center;margin-bottom:8px;&quot;&gt;&lt;font style=&quot;font-size:14px;&quot; color=&quot;#3949ab&quot;&gt;&lt;b&gt;TECHNOLOGY &amp;amp; TOOLS&lt;/b&gt;&lt;/font&gt;&lt;/div&gt;&lt;hr style=&quot;border:0;border-top:1px solid #8c9ae0;margin:4px 0 8px 0;&quot;&gt;&lt;div style=&quot;text-align:left;font-size:12px;line-height:1.5;&quot;&gt;&lt;table style=&quot;width:100%;border-collapse:collapse;font-size:12px;&quot;&gt;&lt;tr&gt;&lt;td style=&quot;padding:8px;vertical-align:top;width:20%;&quot;&gt;&lt;b&gt;CLI &amp;amp; Plugins&lt;/b&gt;&lt;br&gt;- DoiT CLI&lt;br&gt;- Claude Code Plugin&lt;br&gt;- OpenCode Plugin&lt;br&gt;- Git hooks (pre-commit)&lt;/td&gt;&lt;td style=&quot;padding:8px;vertical-align:top;width:20%;border-left:1px solid #5c6bc0;&quot;&gt;&lt;b&gt;CI/CD &amp;amp; Source Control&lt;/b&gt;&lt;br&gt;- GitHub (repos, PRs)&lt;br&gt;- GitHub Actions&lt;br&gt;- GitHub App (DoiT)&lt;br&gt;- Branch protection rules&lt;/td&gt;&lt;td style=&quot;padding:8px;vertical-align:top;width:20%;border-left:1px solid #5c6bc0;&quot;&gt;&lt;b&gt;Cloud Run Services&lt;/b&gt;&lt;br&gt;- Pricing Proxy Service&lt;br&gt;- DCI Interaction Service&lt;br&gt;- DoiT Compute Service&lt;br&gt;- Load Balancers (GLB)&lt;/td&gt;&lt;td style=&quot;padding:8px;vertical-align:top;width:20%;border-left:1px solid #5c6bc0;&quot;&gt;&lt;b&gt;APIs&lt;/b&gt;&lt;br&gt;- /pricing/{service}/{resource}&lt;br&gt;- /usage/nat-gateway?account=&lt;br&gt;- DCI Platform APIs&lt;br&gt;- Cloud provider billing APIs&lt;/td&gt;&lt;td style=&quot;padding:8px;vertical-align:top;width:20%;border-left:1px solid #5c6bc0;&quot;&gt;&lt;b&gt;Monitoring &amp;amp; Dashboards&lt;/b&gt;&lt;br&gt;- DCI Console (web)&lt;br&gt;- Anomaly detection engine&lt;br&gt;- Budget alerts system&lt;br&gt;- Cost allocation reports&lt;/td&gt;&lt;/tr&gt;&lt;/table&gt;&lt;/div&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e8eaf6;strokeColor=#5c6bc0;strokeWidth=2;arcSize=4;verticalAlign=top;spacingTop=8;spacingLeft=10;spacingRight=10;" vertex="1" parent="1">
          <mxGeometry x="40" y="820" width="2120" height="200" as="geometry" />
        </mxCell>

        <!-- ==================== ROW 4: BOTTOM ROW (2 columns) ==================== -->

        <!-- 9. COST STRUCTURE -->
        <mxCell id="cost-box" value="&lt;div style=&quot;text-align:center;margin-bottom:8px;&quot;&gt;&lt;font style=&quot;font-size:14px;&quot; color=&quot;#c62828&quot;&gt;&lt;b&gt;COST STRUCTURE&lt;/b&gt;&lt;/font&gt;&lt;/div&gt;&lt;hr style=&quot;border:0;border-top:1px solid #e09a9a;margin:4px 0 8px 0;&quot;&gt;&lt;div style=&quot;text-align:left;font-size:12px;line-height:1.6;&quot;&gt;&lt;table style=&quot;width:100%;font-size:12px;&quot;&gt;&lt;tr&gt;&lt;td style=&quot;padding:6px;vertical-align:top;width:33%;&quot;&gt;&lt;b&gt;Infrastructure&lt;/b&gt;&lt;br&gt;- Cloud Run hosting&lt;br&gt;- Load balancer costs&lt;br&gt;- API gateway / egress&lt;/td&gt;&lt;td style=&quot;padding:6px;vertical-align:top;width:33%;&quot;&gt;&lt;b&gt;Licensing&lt;/b&gt;&lt;br&gt;- DoiT DCI platform fees&lt;br&gt;- GitHub Enterprise&lt;br&gt;- Claude Code API usage&lt;/td&gt;&lt;td style=&quot;padding:6px;vertical-align:top;width:33%;&quot;&gt;&lt;b&gt;People&lt;/b&gt;&lt;br&gt;- FinOps team headcount&lt;br&gt;- Platform engineering time&lt;br&gt;- Training &amp;amp; certification&lt;/td&gt;&lt;/tr&gt;&lt;/table&gt;&lt;/div&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fce4ec;strokeColor=#e57373;strokeWidth=2;arcSize=4;verticalAlign=top;spacingTop=8;spacingLeft=10;spacingRight=10;" vertex="1" parent="1">
          <mxGeometry x="40" y="1040" width="1050" height="200" as="geometry" />
        </mxCell>

        <!-- 10. KPI & METRICS -->
        <mxCell id="kpi-box" value="&lt;div style=&quot;text-align:center;margin-bottom:8px;&quot;&gt;&lt;font style=&quot;font-size:14px;&quot; color=&quot;#2e7d32&quot;&gt;&lt;b&gt;KPI &amp;amp; SOP METRICS&lt;/b&gt;&lt;/font&gt;&lt;/div&gt;&lt;hr style=&quot;border:0;border-top:1px solid #81c784;margin:4px 0 8px 0;&quot;&gt;&lt;div style=&quot;text-align:left;font-size:12px;line-height:1.6;&quot;&gt;&lt;table style=&quot;width:100%;font-size:12px;&quot;&gt;&lt;tr&gt;&lt;td style=&quot;padding:6px;vertical-align:top;width:33%;&quot;&gt;&lt;b&gt;Efficiency&lt;/b&gt;&lt;br&gt;- % commits with cost check&lt;br&gt;- Mean time to cost feedback&lt;br&gt;- Pre-commit pass rate&lt;/td&gt;&lt;td style=&quot;padding:6px;vertical-align:top;width:33%;&quot;&gt;&lt;b&gt;Effectiveness&lt;/b&gt;&lt;br&gt;- Cost avoided ($ pre-deploy)&lt;br&gt;- Anomalies caught within SLA&lt;br&gt;- Budget variance (actual vs plan)&lt;/td&gt;&lt;td style=&quot;padding:6px;vertical-align:top;width:33%;&quot;&gt;&lt;b&gt;Adoption&lt;/b&gt;&lt;br&gt;- Teams onboarded (%)&lt;br&gt;- CLI / plugin daily active users&lt;br&gt;- FinOps maturity score (crawl/walk/run)&lt;/td&gt;&lt;/tr&gt;&lt;/table&gt;&lt;/div&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e8f5e9;strokeColor=#4caf50;strokeWidth=2;arcSize=4;verticalAlign=top;spacingTop=8;spacingLeft=10;spacingRight=10;" vertex="1" parent="1">
          <mxGeometry x="1110" y="1040" width="1050" height="200" as="geometry" />
        </mxCell>

        <!-- ==================== FLOW ARROWS ==================== -->
        <mxCell id="arrow1" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#9e9e9e;strokeWidth=1;dashed=1;exitX=1;exitY=0.5;exitDx=0;exitDy=0;entryX=0;entryY=0.3;entryDx=0;entryDy=0;" edge="1" parent="1" source="partners-box" target="value-box">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="arrow2" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#9e9e9e;strokeWidth=1;dashed=1;exitX=0;exitY=0.5;exitDx=0;exitDy=0;entryX=1;entryY=0.3;entryDx=0;entryDy=0;" edge="1" parent="1" source="customers-box" target="value-box">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="arrow3" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#9e9e9e;strokeWidth=1;dashed=1;exitX=0.5;exitY=0;exitDx=0;exitDy=0;entryX=0.5;entryY=1;entryDx=0;entryDy=0;" edge="1" parent="1" source="processes-box" target="value-box">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="arrow4" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#9e9e9e;strokeWidth=1;dashed=1;exitX=0.5;exitY=0;exitDx=0;exitDy=0;entryX=0.5;entryY=1;entryDx=0;entryDy=0;" edge="1" parent="1" source="tech-box" target="processes-box">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- ==================== FOOTER ==================== -->
        <mxCell id="footer" value="&lt;font color=&quot;#888888&quot; style=&quot;font-size:11px;&quot;&gt;DoiTOps Service Operating Model Canvas | Adapted from &quot;The Strategy Journey&quot; by Julie Choo | March 2026&lt;/font&gt;" style="text;html=1;align=center;verticalAlign=middle;whiteSpace=wrap;" vertex="1" parent="1">
          <mxGeometry x="660" y="1260" width="880" height="30" as="geometry" />
        </mxCell>

      </root>
    </mxGraphModel>
  </diagram>
